    "import pandas as pd\n",
    " \n",
    "df = pd.read_csv('../data/winequality-red.csv')\n",
    "# display(df.head())\n",
    "shape = df.shape\n",
    "dimention = df.ndim\n",
    "dtypes = df.dtypes\n",
    "describe = df.describe()\n",
    "\n",
    "display(df.head())\n",
    "print('Shape:', shape)\n",
    "print('Dimention:', dimention)\n",
    "print('Data Types:\\n', dtypes)\n",
    "# print('Columns:\\n', columns)\n",
    "# print('Info:\\n', info)\n",
    "print('Describe:\\n', describe)\n",
    "\n"
   ]
